{
  "name": "@stellardao/cli",
  "version": "0.2.0",
  "private": true,
  "description": "Command-line interface for StellarDAO operations",
  "type": "module",
  "main": "./src/index.ts",
  "bin": {
    "stellardao": "./src/index.ts"
  },
  "scripts": {
    "cli": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist .turbo",
    "build": "tsc --project tsconfig.json"
  },
  "dependencies": {},
  "devDependencies": {
    "@stellardao/eslint-config": "workspace:*",
    "@stellardao/tsconfig": "workspace:*",
    "@types/node": "^20.14.10",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3",
    "eslint": "^9.13.0"
  }
}
