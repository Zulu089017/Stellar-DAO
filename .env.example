# ═══════════════════════════════════════════════════════════════
# StellarDAO — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to `.env` and fill in your values.
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ── Network ───────────────────────────────────────────────────
NODE_ENV=development
STELLAR_NETWORK=TESTNET
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# ── RPC Endpoints ─────────────────────────────────────────────
HORIZON_URL=https://horizon-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
ETHEREUM_RPC_URL=https://eth.llamarpc.com
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
POLYGON_RPC_URL=https://polygon-rpc.com

# ── Contract IDs (deployed via `pnpm contracts:deploy`) ──────
BRIDGE_CONTRACT_ID=
FACTORY_CONTRACT_ID=
GOVERNANCE_CONTRACT_ID=
GOVERNANCE_TOKEN_ID=
TIMELOCK_CONTRACT_ID=

# ── Relayer ───────────────────────────────────────────────────
RELAYER_SECRET_KEY=
RELAYER_PUBLIC_KEY=
RELAYER_THRESHOLD=2

# ── API ───────────────────────────────────────────────────────
API_PORT=4000
API_KEYS=dev-key-1,dev-key-2
RELAYER_HMAC_SECRET=dev-hmac-secret

# ── Database (PostgreSQL via Drizzle ORM) ─────────────────────
DATABASE_URL=postgres://stellardao:stellardao@localhost:5432/stellardao

# ── Web (Next.js) — Public env vars (exposed to browser) ─────
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_BRIDGE_CONTRACT_ID=
NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_DEMO_WRAPPER_TOKEN=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAD2KM

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info
