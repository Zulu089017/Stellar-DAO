# ── StellarDAO environment configuration ──────────────────────
# Copy this file to `.env` and fill in your values.
# All variables documented below. See docs/SETUP.md for details.

# ── Stellar Network ───────────────────────────────────────────
# One of: PUBLIC, TESTNET, FUTURENET
STELLAR_NETWORK=TESTNET
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
HORIZON_URL=https://horizon-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# ── Contract IDs (Soroban) ────────────────────────────────────
# Populated by `pnpm contracts:deploy`. Leave empty until deployed.
# Must start with 'C' (Soroban contract ID prefix).
BRIDGE_CONTRACT_ID=
FACTORY_CONTRACT_ID=
WRAPPER_TOKEN_TEMPLATE_ID=

# ── Governance Contract IDs ───────────────────────────────────
# Populated by `pnpm contracts:deploy`.
GOVERNANCE_TOKEN_ID=
GOVERNANCE_CONTRACT_ID=
TIMELOCK_CONTRACT_ID=

# ── Relayer ───────────────────────────────────────────────────
# Secret key (Stellar S-address) for signing attestations.
# Public key derived from the secret — used for verifier registration.
RELAYER_SECRET_KEY=
RELAYER_PUBLIC_KEY=
# Number of relayer attestations required for a mint/burn (default: 2).
RELAYER_THRESHOLD=2

# ── Relayer HMAC Secret ───────────────────────────────────────
# Shared secret for HMAC-SHA256 webhook signature verification.
# Production deployments MUST set this. Leave empty for local dev.
RELAYER_HMAC_SECRET=

# ── Source Chain RPC URLs ─────────────────────────────────────
ETHEREUM_RPC_URL=https://eth.llamarpc.com
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
POLYGON_RPC_URL=https://polygon-rpc.com

# ── API Configuration ─────────────────────────────────────────
# Port the Fastify server listens on (default: 4000).
API_PORT=4000
# PostgreSQL connection string for Drizzle ORM (optional).
# When absent, the API uses in-memory repositories.
# DATABASE_URL=postgres://user:password@localhost:5432/stellardao

# ── API Keys ──────────────────────────────────────────────────
# Comma-separated list of valid API keys for Bearer token auth.
API_KEYS=

# ── Web (Next.js) ─────────────────────────────────────────────
# Prefixed vars are bundled into the client at build time.
# Falls back to non-prefixed vars when NEXT_PUBLIC_* is absent.
NEXT_PUBLIC_HORIZON_URL=
NEXT_PUBLIC_SOROBAN_RPC_URL=
NEXT_PUBLIC_BRIDGE_CONTRACT_ID=
NEXT_PUBLIC_FACTORY_CONTRACT_ID=
NEXT_PUBLIC_NETWORK_PASSPHRASE=
