# ── StellarDAO pre-commit hooks ────────────────────────────────
# Runs on every `git commit`. Keeps the repo clean without
# waiting for CI to catch issues.
#
# Install:  pnpm install   (runs `husky` automatically via `prepare`)

echo "🔍 Running pre-commit checks…"

# Format and lint staged files via lint-staged (uses pnpm for resolution)
pnpm exec lint-staged

echo "✅ Pre-commit checks passed"
