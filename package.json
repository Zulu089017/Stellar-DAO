{
  "name": "stellardao",
  "version": "0.1.0",
  "private": true,
  "description": "StellarDAO — a cross-chain wrapping middleware that lets developers on Ethereum, Solana and Polygon spin up wrapped versions of their tokens on Stellar, with Horizon-powered real-time updates.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.11.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml,rust,toml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml,rust,toml}\"",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "contracts:build": "pnpm --filter @stellardao/contracts build",
    "contracts:test": "pnpm --filter @stellardao/contracts test",
    "contracts:deploy": "pnpm tsx scripts/deploy.ts",
    "bindings:generate": "pnpm tsx scripts/generate-bindings.ts"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "prettier": "^3.3.3",
    "prettier-plugin-rust": "^0.1.7",
    "tsx": "^4.19.0",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@eslint/eslintrc": "^3.1.0"
  }
}
